// workspace-kit-source: .workspace-kit/templates/fabro/workflow.fabro
// workspace-kit-sync: v1.5.0 | synced: 2026-04-18
// timeguesser-overrides: model_stylesheet values, prompt roots, and repo-specific verification nodes
digraph TimeGuesserDelivery {
    graph [
        goal="Execute TimeGuesser Delivery mode in Fabro while preserving harness artifacts and repo guardrails",
        default_max_retry=3,
        model_stylesheet="
          * { model: gpt-5-mini; reasoning_effort: low; }
          .route-design { model: gpt-5.4; reasoning_effort: medium; }
          .route-gate { model: gpt-5-mini; reasoning_effort: low; }
          .route-implement { model: gpt-5.3-codex; reasoning_effort: high; }
          .route-verify-fixup { model: gpt-5.2-codex; reasoning_effort: medium; }
          .route-review { model: gpt-5.4; reasoning_effort: medium; }
          .route-draft { model: gpt-5-mini; reasoning_effort: low; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    load_intake [label="Load Intake", shape=parallelogram, script="mkdir -p \"$artifact_dir\" && test -f \"$goal_file\""]
    spec        [label="Spec", class="route-design", prompt="Read .fabro/timeguesser-delivery/prompts/spec.md, then read the intake at $goal_file and only any additional files explicitly required by that prompt before writing or updating $artifact_dir/spec.md."]
    plan        [label="Plan", class="route-design", prompt="Read .fabro/timeguesser-delivery/prompts/plan.md, then read $artifact_dir/spec.md and only any additional files explicitly required by that prompt before writing or updating $artifact_dir/plan.md."]
    approve     [shape=hexagon, label="Approve Plan"]
    blocked     [label="Blocked / Escalated", class="route-gate", shape=tab, prompt="Summarize why the run stopped, which ask-first boundary or open question blocked execution, and what the human operator must decide next. Do not make further changes."]
    implement   [label="Implement", class="route-implement", prompt="Read .fabro/timeguesser-delivery/prompts/implement.md, then read $artifact_dir/plan.md and only the additional artifacts and implementation files explicitly required by that prompt before implementing the approved changes."]
    choose_verify [shape=hexagon, label="Choose Verification"]
    verify_standard [label="Verify Standard", shape=parallelogram, script="npm run check 2>&1", goal_gate=true, retry_target="fixup"]
    verify_smoke    [label="Verify UI Smoke", shape=parallelogram, script="npm run check 2>&1 && npm run test:maestro:smoke:auto 2>&1", goal_gate=true, retry_target="fixup"]
    verify_full     [label="Verify UI Full", shape=parallelogram, script="npm run check 2>&1 && npm run test:maestro:auto 2>&1", goal_gate=true, retry_target="fixup"]
    fixup        [label="Fixup", class="route-verify-fixup", prompt="A verification step failed. Read .fabro/timeguesser-delivery/prompts/implement.md, the command output from context, $artifact_dir/plan.md, and only the additional artifacts and implementation files explicitly required by that prompt. Fix the issues without broadening scope and preserve the approved plan intent.", max_visits=3]
    review              [label="Review", class="route-review", prompt="Read .fabro/timeguesser-delivery/prompts/review.md, then read $artifact_dir/spec.md, $artifact_dir/plan.md, verification context, and any ADRs explicitly cited there before writing or updating $artifact_dir/review.md."]
    semantic_cycle_gate [label="Semantic Cycle Gate", shape=parallelogram, script="python3 -c \"import re,sys; txt=open('$artifact_dir/review.md').read(); c=re.search(r'Semantic cycle: ([0-9]+)',txt); m=re.search(r'Semantic cycle max: ([0-9]+)',txt); sys.exit(0 if c and m and int(c.group(1)) < int(m.group(1)) else 1)\""]
    handoff             [label="Handoff", class="route-draft", prompt="Read .fabro/timeguesser-delivery/prompts/handoff.md, then read the current ticket artifact chain, verification context, and any ADRs explicitly cited by spec.md or plan.md before writing or updating $artifact_dir/handoff.md."]

    start -> load_intake -> spec -> plan -> approve
    approve -> implement [label="[A] Approve"]
    approve -> plan      [label="[R] Revise"]
    approve -> blocked   [label="[E] Escalate"]
    blocked -> exit
    implement -> choose_verify
    choose_verify -> verify_standard [label="[S] Standard"]
    choose_verify -> verify_smoke    [label="[U] UI Smoke"]
    choose_verify -> verify_full     [label="[F] UI Full"]
    verify_standard -> review [condition="outcome=success"]
    verify_standard -> fixup
    verify_smoke -> review [condition="outcome=success"]
    verify_smoke -> fixup
    verify_full -> review [condition="outcome=success"]
    verify_full -> fixup
    fixup -> choose_verify
    review -> handoff             [label="[P] Proceed"]
    review -> semantic_cycle_gate [label="[RR] Revise and Re-verify"]
    review -> blocked             [label="[E] Escalate"]
    semantic_cycle_gate -> implement [condition="outcome=success"]
    semantic_cycle_gate -> blocked
    handoff -> exit
}
