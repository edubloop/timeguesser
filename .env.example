# Copy this file to .env.local and fill in values.

# Europeana API key — register at https://apis.europeana.eu/
# Required to enable the Europeana image source (Phase C).
EXPO_PUBLIC_EUROPEANA_API_KEY=

# Feature flags (set to "1" to enable)
EXPO_PUBLIC_ENABLE_LOC_SOURCE=
EXPO_PUBLIC_ENABLE_EUROPEANA_SOURCE=
